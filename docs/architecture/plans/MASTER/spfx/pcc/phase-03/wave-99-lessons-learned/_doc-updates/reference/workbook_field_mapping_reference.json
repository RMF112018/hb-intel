    },
    {
      "workbookField": "Priority",
      "pccField": "improvementActions[].priority",
      "classification": "recordField",
      "required": "conditional"
    },
    {
      "workbookField": "Effort",
      "pccField": "improvementActions[].effort",
      "classification": "recordField",
      "required": "conditional"
    },
    {
      "workbookField": "Project Executive Approval",
      "pccField": "review.approvers[]",
      "classification": "approvalField",
      "required": "publication"
    },
    {
      "workbookField": "VP of Operations Approval",
      "pccField": "review.finalApproval",
      "classification": "approvalField",
      "required": "critical-or-company-publication"
    }
  ]
}
