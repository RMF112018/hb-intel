{
  "module": "lessons-learned-center",
  "mappingPolicy": "Every workbook field survives as a target field, taxonomy seed, metric seed, review field, approval field, evidence field, or legacy source-only field.",
  "mappings": [
    {
      "workbookField": "Project Name",
      "pccField": "projectName",
      "classification": "recordField",
      "required": "derived"
    },
    {
      "workbookField": "Project Number",
      "pccField": "projectNumber",
      "classification": "recordField",
      "required": "derived"
    },
    {
      "workbookField": "Category",
      "pccField": "category",
      "classification": "classificationField",
      "required": "submit"
    },
    {
      "workbookField": "Phase Encountered",
      "pccField": "phaseEncountered",
      "classification": "classificationField",
      "required": "submit"
    },
    {
      "workbookField": "Situation",
      "pccField": "content.situation",
      "classification": "recordField",
      "required": "submit"
    },
    {
      "workbookField": "Impact",
      "pccField": "content.impactSummary",
      "classification": "impactField",
      "required": "submit"
    },
    {
      "workbookField": "Root Cause",
      "pccField": "content.rootCause",
      "classification": "recordField",
      "required": "submit"
    },
    {
      "workbookField": "Response",
      "pccField": "content.responseTaken",
      "classification": "recordField",
      "required": "review"
    },
    {
      "workbookField": "Recommendation",
      "pccField": "content.recommendation",
      "classification": "recordField",
      "required": "submit"
    },
    {
      "workbookField": "Supporting Documents / References",
      "pccField": "evidence[]",
      "classification": "evidenceField",
      "required": "publication"
    },
    {
      "workbookField": "Impact Magnitude",
      "pccField": "impact.impactMagnitude",
      "classification": "impactField",
      "required": "submit"
    },
    {
      "workbookField": "Applicability (1\u20135)",
      "pccField": "reuse.applicabilityRating",
