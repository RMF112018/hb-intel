{
  "module": "lessons-learned-center",
  "primaryObject": "PccLessonLearnedRecord",
  "states": [
    "draft",
    "needs-enrichment",
    "submitted-for-review",
    "under-review",
    "approved-project-record",
    "published-company-lesson",
    "converted-to-best-practice",
    "superseded",
    "suppressed",
    "archived-no-action"
  ],
  "terminalStates": [
    "converted-to-best-practice",
    "superseded",
    "suppressed",
    "archived-no-action"
  ],
  "transitions": [
    {
      "from": "draft",
      "action": "submit_for_review",
      "to": "submitted-for-review",
      "actors": [
        "creator",
        "project-manager",
        "project-executive"
      ],
      "requires": [
        "submitRequiredFields",
        "sensitivityClassification",
        "evidenceOrNoEvidenceReason"
      ]
    },
    {
      "from": "submitted-for-review",
      "action": "start_review",
      "to": "under-review",
      "actors": [
        "project-manager",
        "project-executive",
        "assigned-reviewer"
      ]
    },
    {
      "from": "submitted-for-review",
      "action": "request_revision",
      "to": "needs-enrichment",
      "actors": [
        "project-manager",
        "project-executive",
        "assigned-reviewer"
      ],
      "requires": [
        "reviewComment"
      ]
    },
    {
      "from": "needs-enrichment",
      "action": "resubmit",
      "to": "submitted-for-review",
      "actors": [
        "creator",
        "project-manager",
        "project-executive"
      ],
      "requires": [
        "revisionResponse"
      ]
    },
    {
      "from": "under-review",
      "action": "approve_project_record",
      "to": "approved-project-record",
      "actors": [
        "project-manager",
        "project-executive"
      ],
      "requires": [
        "pmValidation",
        "pxSensitivityDecision"
      ]
    },
    {
      "from": "approved-project-record",
      "action": "publish_company_lesson",
      "to": "published-company-lesson",
      "actors": [
        "project-executive",
        "governance-reviewer"
      ],
      "requires": [
        "neutralPublishedSummary",
        "publicationScope",
        "sensitivityClearance"
      ]
    },
    {
      "from": "published-company-lesson",
      "action": "convert_to_best_practice",
      "to": "converted-to-best-practice",
      "actors": [
        "governance-reviewer",
        "department-owner"
      ],
      "requires": [
        "improvementActionOrStandardReference"
      ]
    },
    {
      "from": "approved-project-record",
      "action": "archive_no_action",
      "to": "archived-no-action",
      "actors": [
        "project-executive",
        "governance-reviewer"
      ],
      "requires": [
        "archiveReason"
      ]
    },
    {
      "from": "published-company-lesson",
      "action": "supersede",
      "to": "superseded",
      "actors": [
        "governance-reviewer"
      ],
      "requires": [
        "supersededByLessonId",
        "reason"
      ]
    },
    {
      "from": "*",
      "action": "suppress",
      "to": "suppressed",
      "actors": [
        "project-executive",
        "legal-reviewer",
        "governance-reviewer"
      ],
      "requires": [
        "suppressionReason",
        "auditComment"
      ]
    }
  ],
  "invalidTransitionPolicy": "Reject and emit audit-safe validation error. Do not coerce state transitions."
}
