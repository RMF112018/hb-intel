{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "8119125835785381775"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
      "allowedValues": [
        "staging",
        "prod"
      ],
      "metadata": {
        "description": "Deployment environment name. Staging is the default rollout for Prompt 03."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for resources."
      }
    },
    "functionAppName": {
      "type": "string",
      "metadata": {
        "description": "Function App name for legacy fallback services."
      }
    },
    "hostStorageAccountName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 24,
      "metadata": {
        "description": "Storage account for Function host/runtime state."
      }
    },
    "hostingPlanName": {
      "type": "string",
      "metadata": {
        "description": "Flex Consumption plan name for Function App hosting. This lane is Flex-only."
      }
    },
    "hostingPlanSkuName": {
      "type": "string",
      "defaultValue": "FC1",
      "metadata": {
        "description": "Flex Consumption plan SKU name. Flex Consumption uses FC1."
      }
    },
    "hostingPlanSkuTier": {
      "type": "string",
      "defaultValue": "FlexConsumption",
      "metadata": {
        "description": "Flex Consumption plan SKU tier."
      }
    },
    "applicationInsightsName": {
      "type": "string",
      "metadata": {
        "description": "Application Insights component name."
      }
    },
    "userAssignedIdentityName": {
      "type": "string",
      "metadata": {
        "description": "User-assigned managed identity name."
      }
    },
    "azureTenantId": {
      "type": "string",
      "metadata": {
        "description": "Tenant ID used by app-only auth."
      }
    },
    "functionRuntimeVersion": {
      "type": "string",
      "defaultValue": "22",
      "metadata": {
        "description": "Runtime major version for the Function worker."
      }
    },
    "sharePointTenantUrl": {
      "type": "string",
      "defaultValue": "https://hedrickbrotherscom.sharepoint.com",
      "metadata": {
        "description": "Canonical SharePoint tenant URL."
      }
    },
    "hbCentralSiteUrl": {
      "type": "string",
      "defaultValue": "https://hedrickbrotherscom.sharepoint.com/sites/HBCentral",
      "metadata": {
        "description": "Canonical HBCentral site URL."
      }
    },
    "pilotManagedAppClientId": {
      "type": "string",
      "defaultValue": "08c399eb-a394-4087-b859-659d493f8dc7",
      "metadata": {
        "description": "Pilot app registration app ID used in this phase."
      }
    },
    "legacyFallbackDiscoveryTimerSchedule": {
      "type": "string",
      "defaultValue": "0 0 2 * * *",
      "metadata": {
        "description": "Timer schedule for legacy fallback discovery (six-field cron, UTC)."
      }
    },
    "legacyFallbackRerunMinIntervalMinutes": {
      "type": "int",
      "defaultValue": 30,
      "metadata": {
        "description": "Minimum cooldown (minutes) between manual reruns."
      }
    },
    "legacyFallbackMatchAnomalyThreshold": {
      "type": "int",
      "defaultValue": 25,
      "metadata": {
        "description": "Anomaly threshold for unmatched + review-required results."
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Key Vault name (same resource group) for secret access role assignment."
      }
    },
    "deploymentPackageContainerName": {
      "type": "string",
      "defaultValue": "legacy-fallback-package",
      "metadata": {
        "description": "Blob container name used by Flex deployment storage."
      }
    }
  },
  "variables": {
    "storageBlobDataContributor": "ba92f5b4-2d11-453d-a403-e96b0029c9fe",
    "storageQueueDataContributor": "974c5e8b-45b9-4653-ba55-5f855dd0fb88",
    "storageTableDataContributor": "0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3",
    "keyVaultSecretsUser": "4633458b-17de-408a-b874-0445c86b69e6",
    "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('hostingPlanName'))]",
    "deploymentPackageContainerUrl": "[format('https://{0}.blob.{1}/{2}', parameters('hostStorageAccountName'), environment().suffixes.storage, parameters('deploymentPackageContainerName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[parameters('hostStorageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "allowBlobPublicAccess": false,
        "minimumTlsVersion": "TLS1_2",
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[parameters('applicationInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "IngestionMode": "ApplicationInsights"
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-09-01",
      "name": "[parameters('hostingPlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('hostingPlanSkuName')]",
        "tier": "[parameters('hostingPlanSkuTier')]"
      },
      "kind": "functionapp",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[parameters('userAssignedIdentityName')]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default', parameters('hostStorageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/default/{1}', parameters('hostStorageAccountName'), parameters('deploymentPackageContainerName'))]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned, UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')))]": {}
        }
      },
      "properties": {
        "serverFarmId": "[variables('serverFarmId')]",
        "httpsOnly": true,
        "functionAppConfig": {
          "deployment": {
            "storage": {
              "type": "blobcontainer",
              "value": "[variables('deploymentPackageContainerUrl')]",
              "authentication": {
                "type": "userassignedidentity",
                "userAssignedIdentityResourceId": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName'))]",
                "storageAccountConnectionStringName": null
              }
            }
          },
          "runtime": {
            "name": "node",
            "version": "[parameters('functionRuntimeVersion')]"
          },
          "scaleAndConcurrency": {
            "maximumInstanceCount": 100,
            "instanceMemoryMB": 2048
          }
        },
        "siteConfig": {
          "minTlsVersion": "1.2",
          "ftpsState": "Disabled",
          "linuxFxVersion": "",
          "appSettings": [
            {
              "name": "AzureWebJobsStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix={2}', parameters('hostStorageAccountName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName')), '2023-05-01').keys[0].value, environment().suffixes.storage)]"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', parameters('applicationInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[reference(resourceId('Microsoft.Insights/components', parameters('applicationInsightsName')), '2020-02-02').InstrumentationKey]"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_ENABLED",
              "value": "true"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_DISCOVERY_ENABLED",
              "value": "true"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_HOSTING_ENV",
              "value": "[parameters('environmentName')]"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_FUNCTION_APP_NAME",
              "value": "[parameters('functionAppName')]"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_FUNCTION_HOST_URL",
              "value": "[format('https://{0}.azurewebsites.net', parameters('functionAppName'))]"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_HBCENTRAL_SITE_URL",
              "value": "[parameters('hbCentralSiteUrl')]"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_AUTH_POSTURE",
              "value": "pilot-interim"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_MANAGED_APP_CLIENT_ID",
              "value": "[parameters('pilotManagedAppClientId')]"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_GRAPH_SCOPE",
              "value": "https://graph.microsoft.com/.default"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_TARGET_AUTH_MODEL",
              "value": "least-privilege-sites-selected"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_TARGET_AUTH_MODEL_NOTES",
              "value": "Target production posture: Sites.Selected least privilege for source and HBCentral hosts."
            },
            {
              "name": "HBC_LEGACY_FALLBACK_DISCOVERY_TIMER_ENABLED",
              "value": "false"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_DISCOVERY_TIMER_SCHEDULE",
              "value": "[parameters('legacyFallbackDiscoveryTimerSchedule')]"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_MANUAL_RERUN_ENABLED",
              "value": "true"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_RERUN_MIN_INTERVAL_MINUTES",
              "value": "[string(parameters('legacyFallbackRerunMinIntervalMinutes'))]"
            },
            {
              "name": "HBC_LEGACY_FALLBACK_MATCH_ANOMALY_THRESHOLD",
              "value": "[string(parameters('legacyFallbackMatchAnomalyThreshold'))]"
            },
            {
              "name": "AZURE_TENANT_ID",
              "value": "[parameters('azureTenantId')]"
            },
            {
              "name": "AZURE_CLIENT_ID",
              "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), '2023-01-31').clientId]"
            },
            {
              "name": "SHAREPOINT_TENANT_URL",
              "value": "[parameters('sharePointTenantUrl')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', parameters('applicationInsightsName'))]",
        "[resourceId('Microsoft.Web/serverfarms', parameters('hostingPlanName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), variables('storageBlobDataContributor'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), '2023-01-31').principalId]",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('storageBlobDataContributor'))]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), variables('storageQueueDataContributor'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), '2023-01-31').principalId]",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('storageQueueDataContributor'))]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), variables('storageTableDataContributor'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), '2023-01-31').principalId]",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('storageTableDataContributor'))]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('hostStorageAccountName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName'))]"
      ]
    },
    {
      "condition": "[not(empty(parameters('keyVaultName')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), variables('keyVaultSecretsUser'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), '2023-01-31').principalId]",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', variables('keyVaultSecretsUser'))]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName'))]"
      ]
    }
  ],
  "outputs": {
    "legacyFallbackFunctionAppName": {
      "type": "string",
      "value": "[parameters('functionAppName')]"
    },
    "legacyFallbackFunctionAppHostUrl": {
      "type": "string",
      "value": "[format('https://{0}.azurewebsites.net', parameters('functionAppName'))]"
    },
    "legacyFallbackUserAssignedIdentityClientId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), '2023-01-31').clientId]"
    },
    "legacyFallbackUserAssignedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', parameters('userAssignedIdentityName')), '2023-01-31').principalId]"
    },
    "legacyFallbackStorageAccountName": {
      "type": "string",
      "value": "[parameters('hostStorageAccountName')]"
    },
    "legacyFallbackDeploymentPackageContainer": {
      "type": "string",
      "value": "[format('{0}/default/{1}', parameters('hostStorageAccountName'), parameters('deploymentPackageContainerName'))]"
    },
    "legacyFallbackApplicationInsightsName": {
      "type": "string",
      "value": "[parameters('applicationInsightsName')]"
    }
  }
}