{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)"
    ],
    "ask": [
      "Edit",
      "Write",
      "MultiEdit",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm exec:*)",
      "Bash(npx:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": []
  },
  "env": {
    "HB_ALLOW_CANONICAL_PLAN_LIBRARY_WRITE": "1"
  }
}
