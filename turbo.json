{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": ["pnpm-workspace.yaml"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "pnpm-workspace.yaml",
        "tsconfig*.json",
        "**/tsconfig*.json",
        "package.json"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "pnpm-workspace.yaml",
        ".eslintrc.*",
        "eslint.config.*",
        ".eslintignore",
        "packages/eslint-plugin-hbc/**"
      ],
      "outputs": []
    },
    "check-types": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "pnpm-workspace.yaml",
        "tsconfig*.json",
        "**/tsconfig*.json",
        ".env*"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": [
        "src/**",
        "*.test.ts",
        "*.spec.ts",
        "vitest.config.*",
        "vitest.workspace.ts"
      ],
      "outputs": ["coverage/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".storybook/**"],
      "outputs": ["storybook-static/**"]
    },
    "bundle-report": {
      "dependsOn": ["bundle:size"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "packages/spfx/scripts/report-bundle-size.mjs",
        "packages/spfx/dist/**"
      ],
      "outputs": []
    },
    "bundle:size": {
      "dependsOn": ["build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "packages/spfx/scripts/report-bundle-size.mjs",
        "packages/spfx/dist/**"
      ],
      "outputs": []
    },
    "format:check": {},
    "validate-manifests": {
      "dependsOn": [],
      "inputs": [
        "apps/*/config/**",
        "apps/*/src/webparts/**/*.manifest.json",
        "tools/validate-manifests.ts"
      ],
      "outputs": []
    }
  }
}
