{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@hbc/models": ["packages/models/src/index.ts"],
      "@hbc/models/*": ["packages/models/src/*"],
      "@hbc/data-access": ["packages/data-access/src/index.ts"],
      "@hbc/data-access/*": ["packages/data-access/src/*"],
      "@hbc/query-hooks": ["packages/query-hooks/src/index.ts"],
      "@hbc/query-hooks/*": ["packages/query-hooks/src/*"],
      "@hbc/ui-kit": ["packages/ui-kit/src/index.ts"],
      "@hbc/ui-kit/*": ["packages/ui-kit/src/*"],
      "@hbc/auth": ["packages/auth/src/index.ts"],
      "@hbc/auth/*": ["packages/auth/src/*"],
      "@hbc/shell": ["packages/shell/src/index.ts"],
      "@hbc/provisioning": ["packages/provisioning/src/index.ts"],
      "@hbc/provisioning/*": ["packages/provisioning/src/*"],
      "@hbc/shell/*": ["packages/shell/src/*"],
      "@hbc/features-accounting": ["packages/features/accounting/src/index.ts"],
      "@hbc/features-accounting/*": ["packages/features/accounting/src/*"],
      "@hbc/features-estimating": ["packages/features/estimating/src/index.ts"],
      "@hbc/features-estimating/*": ["packages/features/estimating/src/*"],
      "@hbc/features-project-hub": ["packages/features/project-hub/src/index.ts"],
      "@hbc/features-project-hub/*": ["packages/features/project-hub/src/*"],
      "@hbc/features-business-development": ["packages/features/business-development/src/index.ts"],
      "@hbc/features-business-development/*": ["packages/features/business-development/src/*"],
      "@hbc/features-leadership": ["packages/features/leadership/src/index.ts"],
      "@hbc/features-leadership/*": ["packages/features/leadership/src/*"],
      "@hbc/features-admin": ["packages/features/admin/src/index.ts"],
      "@hbc/features-admin/*": ["packages/features/admin/src/*"],
      "@hbc/features-safety": ["packages/features/safety/src/index.ts"],
      "@hbc/features-safety/*": ["packages/features/safety/src/*"],
      "@hbc/features-quality-control-warranty": ["packages/features/quality-control-warranty/src/index.ts"],
      "@hbc/features-quality-control-warranty/*": ["packages/features/quality-control-warranty/src/*"],
      "@hbc/features-risk-management": ["packages/features/risk-management/src/index.ts"],
      "@hbc/features-risk-management/*": ["packages/features/risk-management/src/*"],
      "@hbc/features-operational-excellence": ["packages/features/operational-excellence/src/index.ts"],
      "@hbc/features-operational-excellence/*": ["packages/features/operational-excellence/src/*"],
      "@hbc/features-human-resources": ["packages/features/human-resources/src/index.ts"],
      "@hbc/features-human-resources/*": ["packages/features/human-resources/src/*"],
      "@hbc/sharepoint-docs": ["packages/sharepoint-docs/src/index.ts"],
      "@hbc/sharepoint-docs/*": ["packages/sharepoint-docs/src/*"],
      "@hbc/bic-next-move": ["packages/bic-next-move/src/index.ts"],
      "@hbc/bic-next-move/*": ["packages/bic-next-move/src/*"],
      "@hbc/complexity": ["packages/complexity/src/index.ts"],
      "@hbc/complexity/*": ["packages/complexity/src/*"],
      "@hbc/acknowledgment": ["packages/acknowledgment/src/index.ts"],
      "@hbc/acknowledgment/*": ["packages/acknowledgment/src/*"],
      "@hbc/step-wizard": ["packages/step-wizard/src/index.ts"],
      "@hbc/step-wizard/*": ["packages/step-wizard/src/*"],
      "@hbc/versioned-record": ["packages/versioned-record/src/index.ts"],
      "@hbc/versioned-record/*": ["packages/versioned-record/src/*"],
      "@hbc/field-annotations": ["packages/field-annotations/src/index.ts"],
      "@hbc/field-annotations/*": ["packages/field-annotations/src/*"],
      "@hbc/data-seeding": ["packages/data-seeding/src/index.ts"],
      "@hbc/data-seeding/*": ["packages/data-seeding/src/*"],
      "@hbc/notification-intelligence": ["packages/notification-intelligence/src/index.ts"],
      "@hbc/notification-intelligence/*": ["packages/notification-intelligence/src/*"],
      "@hbc/smart-empty-state": ["packages/smart-empty-state/src/index.ts"],
      "@hbc/smart-empty-state/*": ["packages/smart-empty-state/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", "coverage"]
}
