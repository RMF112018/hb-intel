<?xml version="1.0" encoding="utf-8"?>
<!--
  HB Intel Foleon — HB_FoleonHomepagePlacements list schema.
  Authority: docs/reference/sharepoint/list-schemas/hbcentral/lists/hb-foleon-homepage-placements.md
  Code mirror: apps/hb-intel-foleon/src/schema/foleonListSchemas.ts (FOLEON_HOMEPAGE_PLACEMENTS_SCHEMA)

  Cross-list lookup: ContentLookup -> Lists/HB_FoleonContentRegistry.
  Per MS-Learn, when both lists are created in the same feature,
  the Lookup `List` attribute may be the web-relative Url of the
  target ListInstance. The Url value below matches the target
  ListInstance Url in elements.xml character-for-character.
-->
<List xmlns:ows="Microsoft SharePoint"
      Title="Foleon Homepage Placements"
      FolderCreation="FALSE"
      Direction="$Resources:Direction;"
      Url="Lists/HB_FoleonHomepagePlacements"
      BaseType="0"
      EnableContentTypes="FALSE"
      VersioningEnabled="TRUE"
      DisableAttachments="TRUE"
      xmlns="http://schemas.microsoft.com/sharepoint/">
  <MetaData>
    <ContentTypes>
      <ContentTypeRef ID="0x01" />
    </ContentTypes>
    <Fields>
      <Field ID="{B9F50101-F01E-4A10-8010-C0F0E0D10001}" Name="PlacementKey" DisplayName="Placement Key" Type="Choice" Required="TRUE" Indexed="TRUE" Format="Dropdown">
        <CHOICES>
          <CHOICE>Hero</CHOICE>
          <CHOICE>Primary Card</CHOICE>
          <CHOICE>Secondary Card</CHOICE>
          <CHOICE>Carousel</CHOICE>
          <CHOICE>Archive Rail</CHOICE>
        </CHOICES>
      </Field>
      <Field ID="{B9F50102-F01E-4A10-8010-C0F0E0D10002}"
             Name="ContentLookup"
             DisplayName="Content Lookup"
             Type="Lookup"
             List="Lists/HB_FoleonContentRegistry"
             ShowField="Title"
             Required="FALSE"
             Indexed="TRUE" />
      <Field ID="{B9F50103-F01E-4A10-8010-C0F0E0D10003}" Name="ContentIdCache" DisplayName="Content ID Cache" Type="Number" Required="FALSE" Indexed="TRUE" Decimals="0" />
      <Field ID="{B9F50104-F01E-4A10-8010-C0F0E0D10004}" Name="IsActive" DisplayName="Is Active" Type="Boolean" Required="TRUE" Indexed="TRUE">
        <Default>1</Default>
      </Field>
      <Field ID="{B9F50105-F01E-4A10-8010-C0F0E0D10005}" Name="DisplayFrom" DisplayName="Display From" Type="DateTime" Format="DateTime" Required="FALSE" Indexed="TRUE" />
      <Field ID="{B9F50106-F01E-4A10-8010-C0F0E0D10006}" Name="DisplayThrough" DisplayName="Display Through" Type="DateTime" Format="DateTime" Required="FALSE" Indexed="TRUE" />
      <Field ID="{B9F50107-F01E-4A10-8010-C0F0E0D10007}" Name="SortRank" DisplayName="Sort Rank" Type="Number" Required="TRUE" Indexed="TRUE" Decimals="0" />
      <Field ID="{B9F50108-F01E-4A10-8010-C0F0E0D10008}" Name="AudienceGroups" DisplayName="Audience Groups" Type="UserMulti" List="UserInfo" Required="FALSE" Mult="TRUE" UserSelectionMode="1" ShowField="ImnName" />
      <Field ID="{B9F50109-F01E-4A10-8010-C0F0E0D10009}" Name="LayoutVariant" DisplayName="Layout Variant" Type="Choice" Required="FALSE" Indexed="TRUE" Format="Dropdown">
        <CHOICES>
          <CHOICE>Large Feature</CHOICE>
          <CHOICE>Compact Card</CHOICE>
          <CHOICE>Square Tile</CHOICE>
          <CHOICE>Text Rail</CHOICE>
        </CHOICES>
      </Field>
      <Field ID="{B9F5010A-F01E-4A10-8010-C0F0E0D1000A}" Name="AdminNotes" DisplayName="Admin Notes" Type="Note" Required="FALSE" NumLines="6" RichText="FALSE" />
    </Fields>
    <Views>
      <View BaseViewID="1" Type="HTML" WebPartZoneID="Main" DisplayName="All Items" DefaultView="TRUE" MobileView="TRUE" MobileDefaultView="TRUE" SetupPath="pages\viewpage.aspx" ImageUrl="/_layouts/images/generic.png" Url="AllItems.aspx">
        <RowLimit Paged="TRUE">50</RowLimit>
        <Toolbar Type="Standard" />
        <ViewFields>
          <FieldRef Name="LinkTitle" />
        </ViewFields>
      </View>
    </Views>
    <Forms>
      <Form Type="DisplayForm" Url="DispForm.aspx" SetupPath="pages\form.aspx" WebPartZoneID="Main" />
      <Form Type="EditForm" Url="EditForm.aspx" SetupPath="pages\form.aspx" WebPartZoneID="Main" />
      <Form Type="NewForm" Url="NewForm.aspx" SetupPath="pages\form.aspx" WebPartZoneID="Main" />
    </Forms>
  </MetaData>
</List>
