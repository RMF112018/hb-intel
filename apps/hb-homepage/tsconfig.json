{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@hbc/auth/spfx": ["packages/auth/src/spfx/index.ts"],
      "@hbc/auth": ["packages/auth/src/index.ts"],
      "@hbc/homepage-launcher": ["packages/homepage-launcher/src/index.ts"],
      "@hbc/homepage-launcher/*": ["packages/homepage-launcher/src/*"],
      "@hbc/ui-kit/app-shell": ["packages/ui-kit/src/app-shell.ts"],
      "@hbc/ui-kit/homepage": ["packages/ui-kit/src/homepage.ts"],
      "@hbc/ui-kit/primitives": ["packages/ui-kit/src/primitives.ts"],
      "@hbc/ui-kit/theme": ["packages/ui-kit/src/theme/index.ts"],
      "@hbc/ui-kit/icons": ["packages/ui-kit/src/icons/index.tsx"],
      "@hbc/models": ["packages/models/src/index.ts"],
      "@hb-homepage/runtime": ["apps/hb-webparts/src/webparts/hbHomepage/HbHomepage"],
      "@hb-homepage/runtime/*": ["apps/hb-webparts/src/webparts/hbHomepage/*"],
      "@hb-homepage/helpers/*": ["apps/hb-webparts/src/homepage/helpers/*"],
      "@hb-homepage/data/*": ["apps/hb-webparts/src/homepage/data/*"],
      "@hb-homepage/shared/*": ["apps/hb-webparts/src/homepage/shared/*"]
    }
  },
  "include": ["src"],
  "exclude": ["dist"]
}
