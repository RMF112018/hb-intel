{
  "name": "@hbc/functions",
  "version": "0.0.45",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "start": "func start",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run --config vitest.config.ts --project unit",
    "test:smoke": "SMOKE_TEST=true vitest run --config vitest.config.ts --project smoke",
    "test:contract-smoke": "vitest run --config vitest.config.ts --project contract-smoke",
    "test:coverage": "vitest run --config vitest.config.ts --project unit --coverage"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "@azure/functions": "^4.6.0",
    "@azure/identity": "^4.5.0",
    "@hbc/acknowledgment": "workspace:*",
    "@hbc/models": "workspace:*",
    "@hbc/notification-intelligence": "workspace:*",
    "@hbc/provisioning": "workspace:*",
    "@pnp/graph": "^4.18.0",
    "@pnp/logging": "^4.18.0",
    "@pnp/nodejs-commonjs": "^2.15.0",
    "@pnp/sp": "^4.18.0",
    "jose": "^5.9.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ]
}
