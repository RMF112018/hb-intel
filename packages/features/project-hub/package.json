{
  "name": "@hbc/features-project-hub",
  "version": "0.1.16",
  "private": true,
  "description": "Project Hub feature package with SF21 Project Health Pulse scaffold boundaries",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./testing/index.ts"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook:test": "vitest run --passWithNoTests -- storybook-matrix",
    "test:e2e": "pnpm exec playwright test --config playwright.health-pulse.config.ts"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^15.0.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^25.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@hbc/bic-next-move": "workspace:*",
    "@hbc/models": "workspace:*",
    "@hbc/notification-intelligence": "workspace:*",
    "@hbc/project-canvas": "workspace:*",
    "@hbc/query-hooks": "workspace:*",
    "@hbc/ui-kit": "workspace:*",
    "@hbc/versioned-record": "workspace:*",
    "@hbc/complexity": "workspace:*",
    "@hbc/auth": "workspace:*",
    "@hbc/shell": "workspace:*",
    "@hbc/smart-empty-state": "workspace:*",
    "@tanstack/react-query": "^5.75.0"
  }
}
