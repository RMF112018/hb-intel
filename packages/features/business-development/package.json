{
  "name": "@hbc/features-business-development",
  "version": "0.0.1",
  "private": true,
  "description": "Business Development feature package — adapter surfaces over @hbc/score-benchmark and @hbc/strategic-intelligence.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "storybook:test": "vitest run --passWithNoTests -- storybook-matrix",
    "test:e2e": "pnpm exec playwright test --config playwright.score-benchmark.config.ts"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^15.0.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@hbc/models": "workspace:*",
    "@hbc/query-hooks": "workspace:*",
    "@hbc/ui-kit": "workspace:*",
    "@hbc/auth": "workspace:*",
    "@hbc/shell": "workspace:*",
    "@hbc/smart-empty-state": "workspace:*",
    "@hbc/score-benchmark": "workspace:*",
    "@hbc/bic-next-move": "workspace:*",
    "@hbc/project-canvas": "workspace:*",
    "@hbc/complexity": "workspace:*",
    "@hbc/versioned-record": "workspace:*",
    "@hbc/related-items": "workspace:*",
    "@hbc/notification-intelligence": "workspace:*",
    "@hbc/acknowledgment": "workspace:*",
    "@hbc/health-indicator": "workspace:*",
    "@hbc/ai-assist": "workspace:*",
    "@hbc/post-bid-autopsy": "workspace:*",
    "@hbc/step-wizard": "workspace:*",
    "@hbc/strategic-intelligence": "workspace:*"
  }
}
