{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "@hbc/score-benchmark": ["packages/score-benchmark/dist/src/index.d.ts"],
      "@hbc/score-benchmark/testing": ["packages/score-benchmark/dist/testing/index.d.ts"],
      "@hbc/strategic-intelligence": ["packages/strategic-intelligence/dist/src/index.d.ts"],
      "@hbc/strategic-intelligence/testing": ["packages/strategic-intelligence/dist/testing/index.d.ts"],
      "@hbc/features-business-development/testing": ["packages/features/business-development/testing/index.ts"],
      "@hbc/bic-next-move": ["packages/bic-next-move/dist/index.d.ts"],
      "@hbc/complexity": ["packages/complexity/dist/src/index.d.ts"],
      "@hbc/versioned-record": ["packages/versioned-record/dist/src/index.d.ts"],
      "@hbc/versioned-record/*": ["packages/versioned-record/dist/src/*"],
      "@hbc/related-items": ["packages/related-items/dist/src/index.d.ts"],
      "@hbc/project-canvas": ["packages/project-canvas/dist/src/index.d.ts"],
      "@hbc/notification-intelligence": ["packages/notification-intelligence/dist/src/index.d.ts"],
      "@hbc/acknowledgment": ["packages/acknowledgment/src/index.ts"],
      "@hbc/health-indicator": ["packages/health-indicator/dist/index.d.ts"],
      "@hbc/ai-assist": ["packages/ai-assist/dist/src/index.d.ts"],
      "@hbc/post-bid-autopsy": ["packages/post-bid-autopsy/dist/src/index.d.ts"]
    }
  },
  "include": ["src/**/*", "testing/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx", "src/__tests__/**"]
}
