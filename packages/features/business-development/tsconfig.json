{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "@hbc/score-benchmark": ["packages/score-benchmark/src/index.ts"],
      "@hbc/score-benchmark/testing": ["packages/score-benchmark/testing/index.ts"],
      "@hbc/bic-next-move": ["packages/bic-next-move/src/index.ts"],
      "@hbc/complexity": ["packages/complexity/src/index.ts"],
      "@hbc/versioned-record": ["packages/versioned-record/dist/src/index.d.ts"],
      "@hbc/versioned-record/*": ["packages/versioned-record/dist/src/*"],
      "@hbc/related-items": ["packages/related-items/src/index.ts"],
      "@hbc/project-canvas": ["packages/project-canvas/src/index.ts"],
      "@hbc/notification-intelligence": ["packages/notification-intelligence/src/index.ts"],
      "@hbc/health-indicator": ["packages/health-indicator/src/index.ts"],
      "@hbc/ai-assist": ["packages/ai-assist/src/index.ts"],
      "@hbc/post-bid-autopsy": ["packages/post-bid-autopsy/src/index.ts"]
    }
  },
  "include": ["src/**/*", "testing/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx", "src/__tests__/**"]
}
