{
  "name": "@hbc/features-estimating",
  "version": "0.0.1",
  "private": true,
  "description": "Estimating Bid Readiness feature package — domain adapter over @hbc/health-indicator for pursuit readiness scoring",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": ["dist", "testing"],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.json --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint src testing --ext .ts,.tsx --config ../../../.eslintrc.base.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "test:storybook:ci": "node ./scripts/runStorybookCi.mjs",
    "test:playwright:smoke": "pnpm build-storybook && pnpm exec playwright test --config playwright.smoke.config.ts",
    "verify:boundaries": "node ./scripts/verifyBoundaries.mjs",
    "verify:docs": "node ./scripts/verifyDocs.mjs",
    "verify:release": "pnpm check-types && pnpm lint && pnpm build && pnpm test:coverage && pnpm verify:boundaries && pnpm verify:docs && pnpm test:storybook:ci && pnpm test:playwright:smoke"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-interactions": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/test": "^8.6.0",
    "@storybook/test-runner": "^0.21.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^25.0.0",
    "storybook": "^8.6.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@hbc/models": "workspace:*",
    "@hbc/query-hooks": "workspace:*",
    "@hbc/ui-kit": "workspace:*",
    "@hbc/auth": "workspace:*",
    "@hbc/shell": "workspace:*",
    "@hbc/smart-empty-state": "workspace:*",
    "@hbc/health-indicator": "workspace:*",
    "@hbc/post-bid-autopsy": "workspace:*",
    "@tanstack/react-query": "^5.75.0"
  }
}
