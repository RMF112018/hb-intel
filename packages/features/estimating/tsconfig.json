{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@hbc/post-bid-autopsy": ["packages/post-bid-autopsy/dist/src/index.d.ts"],
      "@hbc/post-bid-autopsy/testing": ["packages/post-bid-autopsy/dist/testing/index.d.ts"],
      "@hbc/features-estimating/testing": ["packages/features/estimating/testing/index.ts"],
      "@hbc/step-wizard": ["packages/step-wizard/dist/src/index.d.ts"]
    }
  },
  "include": ["src/**/*", "testing/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx", "**/*.stories.ts", "**/*.stories.tsx", "src/__tests__/**"]
}
