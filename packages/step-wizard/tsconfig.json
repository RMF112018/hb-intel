{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@hbc/session-state": ["../session-state/src/index.ts"],
      "@hbc/notification-intelligence": ["../notification-intelligence/src/index.ts"],
      "@hbc/bic-next-move": ["../bic-next-move/src/index.ts"],
      "@hbc/ui-kit": ["../ui-kit/src/index.ts"],
      "@hbc/ui-kit/app-shell": ["../ui-kit/src/app-shell.ts"],
      "@hbc/complexity": ["../complexity/src/index.ts"],
      "@hbc/step-wizard/testing": ["./testing/index.ts"]
    }
  },
  "include": ["src/**/*", "testing/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx", ".storybook", "src/**/*.stories.tsx"]
}
