{
  "name": "@hbc/spfx",
  "version": "0.0.18",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./project-sites": {
      "types": "./dist/webparts/projectSites/index.d.ts",
      "import": "./dist/webparts/projectSites/index.js"
    },
    "./project-sites/search-seam": {
      "types": "./dist/webparts/projectSites/searchSeam.d.ts",
      "import": "./dist/webparts/projectSites/searchSeam.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "pnpm --dir ../.. exec vitest run --workspace vitest.workspace.ts packages/spfx/src",
    "test:watch": "pnpm --dir ../.. exec vitest watch --workspace vitest.workspace.ts packages/spfx/src",
    "test:coverage": "pnpm --dir ../.. exec vitest run --coverage --workspace vitest.workspace.ts packages/spfx/src",
    "bundle:size": "node ./scripts/report-bundle-size.mjs"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.0",
    "@griffel/react": "^1.5.0",
    "@hbc/auth": "workspace:*",
    "@hbc/sharepoint-docs": "workspace:*",
    "@hbc/ui-kit": "workspace:*",
    "@pnp/sp": "^4.0.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tanstack/react-query": "^5.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.475.0",
    "motion": "^12.0.0"
  },
  "devDependencies": {
    "@microsoft/sp-core-library": "^1.20.0",
    "@microsoft/sp-http": "^1.20.0",
    "@microsoft/sp-property-pane": "^1.20.0",
    "@microsoft/sp-webpart-base": "^1.20.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^15.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "files": [
    "dist"
  ]
}
