{
  "name": "@hbc/acknowledgment",
  "version": "0.1.1",
  "private": true,
  "description": "Universal acknowledgment and sign-off platform primitive",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/src/server.d.ts",
      "import": "./dist/src/server.js"
    },
    "./testing": {
      "types": "./testing/index.d.ts",
      "import": "./testing/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "testing"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src testing --ext .ts,.tsx --max-warnings 0",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@griffel/react": "^1.5.0",
    "@hbc/complexity": "workspace:*",
    "@hbc/session-state": "workspace:*",
    "@hbc/ui-kit": "workspace:*",
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^25.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  }
}
