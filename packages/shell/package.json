{
  "name": "@hbc/shell",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dev-toolbar": {
      "types": "./dist/devToolbar/index.d.ts",
      "import": "./dist/devToolbar/index.js"
    }
  },
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "tsc --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test": "pnpm --dir ../.. exec vitest run --workspace vitest.workspace.ts packages/shell/src",
    "test:watch": "pnpm --dir ../.. exec vitest watch --workspace vitest.workspace.ts packages/shell/src",
    "test:coverage": "pnpm --dir ../.. exec vitest run --coverage --workspace vitest.workspace.ts packages/shell/src"
  },
  "dependencies": {
    "@hbc/models": "workspace:*",
    "@hbc/auth": "workspace:*",
    "@griffel/react": "^1.5.0",
    "@tanstack/react-table": "^8.21.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^15.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitejs/plugin-react": "^4.4.0",
    "happy-dom": "^18.0.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "files": [
    "dist"
  ]
}
