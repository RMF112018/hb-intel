{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "noEmitOnError": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "baseUrl": "../..",
    "paths": {
      "@hbc/auth/dev": ["packages/shell/src/devToolbar/auth-dev-shim.d.ts"],
      "@hbc/models/*": ["packages/models/src/*"],
      "@hbc/data-access/*": ["packages/data-access/src/*"],
      "@hbc/query-hooks/*": ["packages/query-hooks/src/*"],
      "@hbc/ui-kit/*": ["packages/ui-kit/src/*"],
      "@hbc/auth/*": ["packages/auth/src/*"],
      "@hbc/shell/*": ["packages/shell/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
