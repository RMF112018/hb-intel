{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@hbc/score-benchmark/testing": ["./testing/index.ts"],
      "@hbc/bic-next-move": ["packages/bic-next-move/dist/index.d.ts"],
      "@hbc/bic-next-move/*": ["packages/bic-next-move/dist/*"],
      "@hbc/versioned-record": ["packages/versioned-record/dist/src/index.d.ts"],
      "@hbc/versioned-record/*": ["packages/versioned-record/dist/src/*"]
    }
  },
  "include": ["src/**/*", "testing/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx", "src/__tests__/**"]
}
