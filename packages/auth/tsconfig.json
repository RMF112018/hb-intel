{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "noEmitOnError": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/adapters/__tests__/**",
    "src/adapters/DevAuthBypassAdapter.ts",
    "src/dev.ts",
    "src/mock/**"
  ]
}
