{
  "name": "@hbc/auth",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "import": "./dist/dev.js"
    },
    "./spfx": {
      "types": "./dist/spfx/index.d.ts",
      "import": "./dist/spfx/index.js"
    }
  },
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "tsc --project tsconfig.json",
    "test": "pnpm --dir ../.. exec vitest run --workspace vitest.workspace.ts packages/auth/src",
    "test:watch": "pnpm --dir ../.. exec vitest watch --workspace vitest.workspace.ts packages/auth/src",
    "test:coverage": "pnpm --dir ../.. exec vitest run --coverage --workspace vitest.workspace.ts packages/auth/src",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx --rulesdir ./eslint-rules"
  },
  "dependencies": {
    "@hbc/models": "workspace:*",
    "@pnp/sp": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "optionalDependencies": {
    "@azure/msal-browser": "^4.0.0",
    "@azure/msal-react": "^3.0.0"
  },
  "devDependencies": {
    "@microsoft/sp-webpart-base": "^1.18.0",
    "@types/uuid": "^9.0.8",
    "@types/react": "^18.3.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitejs/plugin-react": "^4.4.0",
    "uuid": "^9.0.1",
    "vitest": "^3.2.4",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "files": [
    "dist"
  ]
}
