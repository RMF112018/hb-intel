{
  "name": "@hbc/project-site-provisioning",
  "version": "0.1.0-scaffold",
  "private": true,
  "description": "Headless deterministic mapper/planner for the SP Project Control Center Standard Project Site Template. Phase 2 contract-coverage mapper plus dry-run proof artifact generator. No tenant mutation, no Graph/PnP, no SPFx, no Procore runtime.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "README.md",
    "proof"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "generate:proof": "tsc --project tsconfig.json && node scripts/generate-baseline-proof.mjs"
  },
  "dependencies": {
    "@hbc/project-site-template": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
