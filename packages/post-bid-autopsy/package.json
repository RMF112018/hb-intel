{
  "name": "@hbc/post-bid-autopsy",
  "version": "0.0.1",
  "private": true,
  "description": "Tier-1 scaffold primitive for post-bid autopsy evidence, confidence, taxonomy, governance, publication, telemetry, and published learning signals.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/src/index.js",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "check-types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@hbc/bic-next-move": "workspace:*",
    "@hbc/score-benchmark": "workspace:*",
    "@hbc/strategic-intelligence": "workspace:*",
    "@hbc/versioned-record": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
