# SPFx packaging runtime configuration — copy to `.env` and fill in.
#
#   cp .env.example .env
#
# `.env` is gitignored. `tools/build-spfx-package.ts` loads this file at the
# start of every run and fills any of these keys that are NOT already set in
# the environment — an explicit `VAR=… npx tsx …` or CI variable always wins.
#
# These are NON-SECRET runtime values: they are stamped into the SPFx shell
# bundle at build time via webpack DefinePlugin (`__FUNCTION_APP_URL__`,
# `__API_AUDIENCE__`, `__BACKEND_MODE__`, `__ALLOW_BACKEND_MODE_SWITCH__`) and
# are therefore visible in the shipped `.sppkg`. Do not put secrets here.

# ── Backend mode ───────────────────────────────────────────────────────────
# Unset / empty / `production`  → production-intended build. For the gated
#   domains (e.g. my-dashboard) this REQUIRES FUNCTION_APP_URL + API_AUDIENCE
#   below, or the build refuses (see
#   tools/build-spfx-package-production-runtime-config.ts).
# `ui-review`  → explicit non-production artifact (fixture data, no live
#   backend). FUNCTION_APP_URL / API_AUDIENCE are not required in this mode.
BACKEND_MODE=production

# ── Function App base URL ──────────────────────────────────────────────────
# The deployed Azure Function App base URL. Current dev Function App
# (resource: hb-intel-function-app, resource group: hb-intel). This hostname
# is non-secret and already appears in repo test fixtures.
FUNCTION_APP_URL=https://hb-intel-function-app-gbd6ecgrh7fsgscm.eastus2-01.azurewebsites.net

# ── API audience ───────────────────────────────────────────────────────────
# The Entra app registration's Application ID URI / token audience that the
# backend validates (see backend/functions/src/middleware/validateToken.ts).
# NOT derivable from the Function App resource JSON — source it from the
# Entra app registration, the deployed backend/functions app settings, or the
# GitHub environment configuration. Replace the placeholder below.
API_AUDIENCE=api://REPLACE-WITH-ENTRA-APP-REGISTRATION-AUDIENCE

# ── Backend mode switch (optional) ─────────────────────────────────────────
# When `true`, allows the loaded app to switch backend mode at runtime.
# Leave empty for normal builds.
ALLOW_BACKEND_MODE_SWITCH=
